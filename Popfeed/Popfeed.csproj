<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <Nullable>disable</Nullable>
    <AssemblyName>jellyfin-popfeed-scrobbler</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Web\popfeed.html" />
    <None Remove="Web\popfeed.js" />
    <EmbeddedResource Include="Web\popfeed.html" />
    <EmbeddedResource Include="Web\popfeed.js" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Jellyfin.Data" Version="10.*-*" />
    <PackageReference Include="Jellyfin.Controller" Version="10.*-*" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="8.*" />
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

</Project>